generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                      Int       @id @default(autoincrement())
  username                String    @unique @db.VarChar(50)
  email                   String    @unique @db.VarChar(150)
  password                String    @db.VarChar(255)
  full_name               String    @default("") @db.VarChar(100)
  phone                   String    @default("") @db.VarChar(20)
  role                    String    @default("customer") @db.VarChar(20)
  status                  String    @default("pending") @db.VarChar(20)
  is_verified             Boolean   @default(false)
  verification_token      String?   @db.VarChar(128)
  verification_token_exp  DateTime?
  failed_login_attempts   Int       @default(0)
  lock_until              DateTime?
  block_reason            String?   @db.VarChar(255)
  created_at              DateTime  @default(now())
  updated_at              DateTime  @default(now())

  refresh_tokens          RefreshToken[]      @relation("RefreshTokenUser")
  password_reset_tokens   PasswordResetToken[]
  reservations            Reservation[]       @relation("ReservationUser")
  processed_reservations  Reservation[]       @relation("ReservationProcessedBy")
  incident_reports        IncidentTicket[]    @relation("IncidentReporter")
  incident_assignments    IncidentTicket[]    @relation("IncidentAssignee")

  @@index([role])
  @@index([status])
  @@map("users")
}

model RefreshToken {
  id         Int      @id @default(autoincrement())
  user_id    Int
  token_hash String   @unique @db.Char(64)
  expires_at DateTime
  created_at DateTime @default(now())

  user       User     @relation("RefreshTokenUser", fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id         Int      @id @default(autoincrement())
  user_id    Int
  token_hash String   @unique @db.Char(64)
  expires_at DateTime
  used       Boolean  @default(false)
  created_at DateTime @default(now())

  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

model LabRoom {
  id          Int           @id @default(autoincrement())
  room_code   String        @unique @db.VarChar(50)
  name        String        @db.VarChar(150)
  location    String        @default("") @db.VarChar(255)
  capacity    Int
  description String?       @db.Text
  status      String        @default("active") @db.VarChar(20)
  created_at  DateTime      @default(now())
  updated_at  DateTime      @default(now())

  workstations Workstation[]
  reservations Reservation[]
  incidents    IncidentTicket[]

  @@index([status])
  @@map("lab_rooms")
}

model Workstation {
  id           Int       @id @default(autoincrement())
  lab_room_id  Int
  station_code String    @db.VarChar(50)
  ip_address   String    @default("") @db.VarChar(45)
  mac_address  String    @default("") @db.VarChar(17)
  cpu          String    @default("") @db.VarChar(100)
  ram_gb       Int       @default(0)
  gpu          String    @default("") @db.VarChar(100)
  os           String    @default("") @db.VarChar(100)
  state        String    @default("available") @db.VarChar(20)
  created_at   DateTime  @default(now())
  updated_at   DateTime  @default(now())

  lab_room     LabRoom   @relation(fields: [lab_room_id], references: [id], onDelete: Restrict)
  reservations Reservation[]
  incidents    IncidentTicket[]

  @@unique([lab_room_id, station_code])
  @@index([state])
  @@map("workstations")
}

model Reservation {
  id             Int        @id @default(autoincrement())
  user_id        Int
  resource_type  String     @db.VarChar(20)
  lab_room_id    Int?
  workstation_id Int?
  start_time     DateTime
  end_time       DateTime
  purpose        String     @default("") @db.VarChar(500)
  expected_users Int        @default(1)
  status         String     @default("pending") @db.VarChar(20)
  reject_reason  String?    @db.VarChar(500)
  processed_by   Int?
  processed_at   DateTime?
  created_at     DateTime   @default(now())
  updated_at     DateTime   @default(now())

  user           User       @relation("ReservationUser", fields: [user_id], references: [id], onDelete: Cascade)
  processed_user User?      @relation("ReservationProcessedBy", fields: [processed_by], references: [id])
  lab_room       LabRoom?   @relation(fields: [lab_room_id], references: [id], onDelete: SetNull)
  workstation    Workstation? @relation(fields: [workstation_id], references: [id], onDelete: SetNull)

  @@index([user_id])
  @@index([status])
  @@index([lab_room_id, start_time, end_time])
  @@index([workstation_id, start_time, end_time])
  @@map("reservations")
}

model IncidentTicket {
  id              Int        @id @default(autoincrement())
  reporter_id     Int
  workstation_id  Int?
  lab_room_id     Int?
  category        String     @db.VarChar(20)
  description     String     @db.Text
  status          String     @default("open") @db.VarChar(20)
  assigned_to     Int?
  resolution_note String?    @db.Text
  created_at      DateTime   @default(now())
  updated_at      DateTime   @default(now())
  resolved_at     DateTime?

  reporter        User       @relation("IncidentReporter", fields: [reporter_id], references: [id], onDelete: Cascade)
  assigned_user   User?      @relation("IncidentAssignee", fields: [assigned_to], references: [id])
  lab_room        LabRoom?   @relation(fields: [lab_room_id], references: [id], onDelete: SetNull)
  workstation     Workstation? @relation(fields: [workstation_id], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([reporter_id])
  @@map("incident_tickets")
}
